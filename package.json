{
  "name": "dev-context",
  "version": "0.1.0",
  "description": "Git-aware AI context generator. Stop wasting tokens teaching AI about your codebase.",
  "keywords": ["git", "ai", "context", "developer-tools", "cli", "llm", "rag", "claude", "copilot"],
  "license": "MIT",
  "author": "dev-context",
  "repository": {
    "type": "git",
    "url": "https://github.com/devcontext/devcontext"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "dev-context": "./dist/bin/cli.js",
    "devcontext": "./dist/bin/cli.js",
    "dctx": "./dist/bin/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/bin/cli.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-spinners": "^3.1.0",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "chokidar": "^4.0.3",
    "glob": "^11.0.0",
    "gradient-string": "^3.0.0",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "log-update": "^6.1.0",
    "ora": "^8.1.0",
    "simple-git": "^3.27.0",
    "tiktoken": "^1.0.18",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/gradient-string": "^1.1.6",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "tsup": {
    "entry": ["src/index.ts", "src/bin/cli.ts"],
    "format": ["esm"],
    "dts": true,
    "clean": true,
    "splitting": false,
    "target": "node18"
  }
}
